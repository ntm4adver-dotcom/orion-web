# كلمة المرور التي تستخدمها لدخول لوحة التحكم على الويب
ORION_APP_PASSWORD=change-this-password

# مفتاح سري عشوائي لتشفير الجلسات (Session) — يمكن توليده بأي سلسلة عشوائية طويلة
ORION_SECRET_KEY=change-this-to-a-long-random-string

# (اختياري) مسار ملف قاعدة البيانات محلياً
ORION_DB_PATH=./data/orion.db
